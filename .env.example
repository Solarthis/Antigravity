# =============================================================================
# PROJECT ANTIGRAVITY — Runtime Configuration Template
# =============================================================================
# This file is the committed template. On first launch, the launcher copies it
# to `.env` (git-ignored) which becomes the single source of runtime config.
# Edit `.env`, not this file.
# =============================================================================

# --- Host port the dashboard is published on -------------------------------
# Change this if 3000 is taken on your host. Inside the container the app
# always listens on 3000; APP_PORT only controls the host→container mapping.
APP_PORT=3000

# --- Twilio [REQUIRED for live alerts; leave blank for dry-run] ------------
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+15005550006
TWILIO_SMS_FROM=+15005550006

# --- Alert Recipients ------------------------------------------------------
# Comma-separated. WhatsApp format: whatsapp:+15551234567. SMS: +15551234567
ALERT_RECIPIENTS_WHATSAPP=
ALERT_RECIPIENTS_SMS=
ADMIN_ALERT_RECIPIENT=

# --- Scraper tuning --------------------------------------------------------
COPART_BASE_URL=https://www.copart.com
SCRAPE_HEADLESS=true
SCRAPE_DELAY_MIN_MS=2000
SCRAPE_DELAY_MAX_MS=8000
SCRAPE_PAGE_TIMEOUT_MS=30000
SCRAPE_MAX_PAGES=10

# --- Cron (every 30 min, 7AM–9PM ET, Mon–Sat) -----------------------------
CRON_SCHEDULE=*/30 7-21 * * 1-6
CRON_TIMEZONE=America/New_York

# --- Internals -------------------------------------------------------------
JOB_LOCK_TTL_MS=300000
MATCH_CONFIDENCE_THRESHOLD=0.6
