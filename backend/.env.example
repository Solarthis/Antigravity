# =============================================================================
# PROJECT ANTIGRAVITY — ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values.
# All fields marked [REQUIRED] must be set before the system will start.

# --- Database (PostgreSQL) [REQUIRED] ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antigravity
DB_USER=postgres
DB_PASSWORD=
DB_MAX_POOL=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# --- Twilio [REQUIRED for alerts] ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+15005550006
TWILIO_SMS_FROM=+15005550006

# --- Alert Recipients (comma-separated) ---
# Format: whatsapp:+15551234567 or +15551234567 (SMS)
ALERT_RECIPIENTS_WHATSAPP=whatsapp:+18551234567
ALERT_RECIPIENTS_SMS=+18551234567
ADMIN_ALERT_RECIPIENT=whatsapp:+18551234567

# --- Scraper ---
COPART_BASE_URL=https://www.copart.com
SCRAPE_HEADLESS=true
SCRAPE_DELAY_MIN_MS=2000
SCRAPE_DELAY_MAX_MS=8000
SCRAPE_PAGE_TIMEOUT_MS=30000
SCRAPE_MAX_PAGES=10

# --- Cron Scheduling ---
# Default: Every 30 min, 7AM-9PM EST, Mon-Sat
CRON_SCHEDULE=*/30 7-21 * * 1-6
CRON_TIMEZONE=America/New_York

# --- Job Lock ---
JOB_LOCK_TTL_MS=300000

# --- Matching ---
MATCH_CONFIDENCE_THRESHOLD=0.6

# --- Server ---
PORT=3000
NODE_ENV=development
